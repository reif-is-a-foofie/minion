{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minion",
  "version": "0.2.6",
  "identifier": "dev.minion.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash src-tauri/scripts/sync_sidecar.sh && bash src-tauri/scripts/ensure_uv.sh && npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Minion",
        "width": 980,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/sidecar": "sidecar",
      "resources/bin": "bin"
    }
  }
}
