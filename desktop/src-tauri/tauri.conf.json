{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minion",
  "version": "1.0.0",
  "identifier": "dev.minion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash src-tauri/scripts/sync_sidecar.sh && bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Minion",
        "width": 980,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "copyright": "Copyright © 2026. Released under the MIT License.",
    "category": "DeveloperTool",
    "shortDescription": "Private local memory and search for your AI assistants.",
    "longDescription": "Minion turns your Mac into searchable long-term memory: drop files into one inbox, chunk and embed locally in SQLite, and let Claude (or any MCP client) recall what you indexed. No hosted corpus — data stays under your account.",
    "homepage": "https://github.com/reif-is-a-foofie/Minion",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/sidecar": "sidecar"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1Q0JEMjhEQjlDN0RDQTAKUldTZzNNZTVqZExMSlcvYTd5Z2tFYVJNNDRnU3Q4dVQwWEpaT0xUOXQ0bVJ6L0pEUVNhNnI5dVEK",
      "endpoints": [
        "https://github.com/reif-is-a-foofie/Minion/releases/latest/download/latest.json"
      ]
    }
  }
}
