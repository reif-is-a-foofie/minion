#!/usr/bin/env python3
from __future__ import annotations

import argparse
import hashlib
import json
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple


def _default_claude_desktop_config_path() -> Path:
    env = os.environ.get("CLAUDE_DESKTOP_CONFIG")
    if env:
        return Path(env).expanduser().resolve()
    if sys.platform == "darwin":
        return Path.home() / "Library/Application Support/Claude/claude_desktop_config.json"
    if sys.platform == "win32":
        appdata = os.environ.get("APPDATA", "")
        if not appdata:
            raise RuntimeError("APPDATA is not set (needed for Claude Desktop config path on Windows)")
        return Path(appdata) / "Claude" / "claude_desktop_config.json"
    return Path.home() / ".config/Claude/claude_desktop_config.json"


def install_claude_desktop_mcp(
    *,
    workspace_dir: Path,
    derived_dir: Path,
    server_name: str = "minion",
    config_path: Optional[Path] = None,
) -> Tuple[Path, Optional[Path]]:
    """
    Merge this MCP server into Claude Desktop's claude_desktop_config.json.
    Backs up the previous file to *.minion.bak when it existed.
    Returns (written_config_path, backup_path_or_None).
    """
    vpy = _ensure_python_env(workspace_dir)
    mcp_script = _src("mcp_server.py")
    # IMPORTANT: do NOT call vpy.resolve(). The venv's bin/python is a symlink
    # to the system interpreter; resolving it dereferences the symlink and
    # Python then loads the system site-packages instead of the venv's,
    # breaking imports (numpy, fastembed, etc.). Keep the venv path verbatim.
    entry: Dict[str, Any] = {
        "command": str(vpy),
        "args": [str(mcp_script.resolve())],
        "env": {"MINION_DATA_DIR": str(derived_dir.resolve())},
    }
    path = config_path or _default_claude_desktop_config_path()
    path = path.expanduser().resolve()
    backup: Optional[Path] = None

    if path.exists():
        backup = path.with_suffix(path.suffix + ".minion.bak")
        shutil.copy2(path, backup)
        raw = path.read_text(encoding="utf-8")
        if raw.strip():
            try:
                config = json.loads(raw)
            except json.JSONDecodeError as e:
                raise SystemExit(
                    f"{path} is not valid JSON ({e}). Fix or remove it, or set CLAUDE_DESKTOP_CONFIG."
                ) from e
        else:
            config = {}
    else:
        config = {}
        path.parent.mkdir(parents=True, exist_ok=True)

    if not isinstance(config, dict):
        raise SystemExit(f"Top-level JSON in {path} must be an object.")

    mcp_servers = config.get("mcpServers")
    if mcp_servers is None:
        config["mcpServers"] = {}
    elif not isinstance(mcp_servers, dict):
        raise SystemExit(f'"mcpServers" in {path} must be an object.')
    config["mcpServers"][server_name] = entry

    text = json.dumps(config, indent=2, ensure_ascii=False) + "\n"
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(text, encoding="utf-8")
    tmp.replace(path)

    return path, backup


def _repo_root() -> Path:
    # When installed via Homebrew, this script lives at: <libexec>/bin/minion
    return Path(__file__).resolve().parents[1]


def _chatgpt_mcp_dir() -> Path:
    return _repo_root() / "chatgpt_mcp_memory"


def _src(script_name: str) -> Path:
    return _chatgpt_mcp_dir() / "src" / script_name


def _run(cmd: List[str], *, cwd: Optional[Path] = None, env: Optional[Dict[str, str]] = None) -> str:
    p = subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        env=env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=True,
    )
    return p.stdout


def _run_explain(cmd: List[str], *, cwd: Optional[Path] = None, env: Optional[Dict[str, str]] = None) -> str:
    """Run a subprocess; print stdout/stderr on failure and exit (for venv/pip UX)."""
    p = subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        env=env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    out = p.stdout or ""
    if p.returncode != 0:
        if out.strip():
            print(out, end="" if out.endswith("\n") else "\n")
        raise SystemExit(
            f"\nThat step failed (exit {p.returncode}). Output is above.\n"
            f"Command: {' '.join(cmd)}"
        )
    return out


def _py_exe_ok(path: str) -> bool:
    try:
        p = subprocess.run(
            [path, "-c", "import sys; raise SystemExit(0 if sys.version_info[:2] >= (3, 10) else 1)"],
            capture_output=True,
            text=True,
            timeout=30,
        )
        return p.returncode == 0
    except OSError:
        return False


def _python_for_venv() -> str:
    """
    Prefer Homebrew python@3.11+ (minion formula already depends on it).
    Avoid Apple CLT python3 (often 3.9) — sentence-transformers wheels expect newer runtimes.
    """
    brew = _which("brew")
    if brew:
        for formula in ("python@3.12", "python@3.11", "python@3.10"):
            try:
                pref = subprocess.run(
                    [brew, "--prefix", formula],
                    capture_output=True,
                    text=True,
                    timeout=45,
                )
                if pref.returncode != 0:
                    continue
                base = Path(pref.stdout.strip())
                for sub in ("bin/python3.12", "bin/python3.11", "bin/python3.10", "bin/python3"):
                    exe = base / sub
                    if exe.is_file() and os.access(exe, os.X_OK) and _py_exe_ok(str(exe)):
                        return str(exe)
            except OSError:
                continue
    for name in ("python3.12", "python3.11", "python3.10"):
        w = _which(name)
        if w and _py_exe_ok(w):
            return w
    py = _which("python3") or _which("python")
    if py and _py_exe_ok(py):
        return py
    raise SystemExit(
        "Minion needs Python 3.10+ to install dependencies (numpy, sentence-transformers).\n"
        "Install with:  brew install python@3.11\n"
        "Or install https://docs.astral.sh/uv/ and re-run minion (uv will use Python 3.11)."
    )


def _requirements_fingerprint(req: Path) -> str:
    return hashlib.sha256(req.read_bytes()).hexdigest()


def _venv_stamp_path(workspace_dir: Path) -> Path:
    return workspace_dir / ".venv" / ".minion_requirements_fp"


def _venv_py_usable(vpy: Path) -> bool:
    if not vpy.is_file():
        return False
    try:
        p = subprocess.run(
            [str(vpy), "-c", "import sys; raise SystemExit(0 if sys.version_info[:2] >= (3, 10) else 1)"],
            capture_output=True,
            text=True,
            timeout=30,
        )
        return p.returncode == 0
    except OSError:
        return False


def _python_u(vpy: Path, script: Path, args: List[str]) -> List[str]:
    """Unbuffered Python so progress logs and tqdm appear immediately."""
    return [str(vpy), "-u", str(script)] + args


def _run_tee(cmd: List[str], *, cwd: Optional[Path] = None, env: Optional[Dict[str, str]] = None) -> str:
    """
    Run a subprocess and stream its stdout to the terminal line-by-line while capturing it.
    Use for long steps (ingest, index, persona) so users see progress instead of a silent hang.
    """
    p = subprocess.Popen(
        cmd,
        cwd=str(cwd) if cwd else None,
        env=env,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
    )
    out_parts: List[str] = []
    assert p.stdout is not None
    for line in iter(p.stdout.readline, ""):
        out_parts.append(line)
        print(line, end="", flush=True)
    p.wait()
    captured = "".join(out_parts)
    if p.returncode != 0:
        raise subprocess.CalledProcessError(p.returncode, cmd, output=captured)
    return captured


def _which(name: str) -> Optional[str]:
    return shutil.which(name)


def _default_workspace_dir() -> Path:
    return Path.home() / "minion_private"

def _workspace_in_cwd() -> Path:
    """
    Default interactive workspace: ./minion_private, or ./minion_private_2, … if taken.
    """
    parent = Path.cwd().resolve()
    candidate = parent / "minion_private"
    if not candidate.exists():
        return candidate
    n = 2
    while True:
        alt = parent / f"minion_private_{n}"
        if not alt.exists():
            return alt
        n += 1


def _workspace_beside_export(export_path: Path) -> Path:
    """
    Place workspace next to the export: parent/minion_private, or minion_private_2, … if taken.
    """
    parent = export_path.resolve().parent
    candidate = parent / "minion_private"
    if not candidate.exists():
        return candidate
    n = 2
    while True:
        alt = parent / f"minion_private_{n}"
        if not alt.exists():
            return alt
        n += 1


def _ensure_dir(path: Path) -> None:
    path.mkdir(parents=True, exist_ok=True)


def _venv_python(workspace_dir: Path) -> Path:
    # uv venv and venv both create workspace/.venv
    return workspace_dir / ".venv" / "bin" / "python"


def _ensure_python_env(workspace_dir: Path) -> Path:
    """
    Prefer uv (fast, less system-python drama). Fall back to venv.
    Returns the python executable path to use for subsequent steps.
    """
    req = _chatgpt_mcp_dir() / "requirements.txt"
    fp = _requirements_fingerprint(req)
    stamp = _venv_stamp_path(workspace_dir)
    _ensure_dir(workspace_dir)

    vpy = _venv_python(workspace_dir)
    if vpy.exists() and not _venv_py_usable(vpy):
        shutil.rmtree(workspace_dir / ".venv")

    vpy = _venv_python(workspace_dir)
    if vpy.exists() and stamp.exists() and stamp.read_text(encoding="utf-8").strip() == fp:
        return vpy

    uv = _which("uv")
    if not vpy.exists():
        if uv:
            _run_explain([uv, "python", "install", "3.11"])
            _run_explain([uv, "venv", "--python", "3.11", str(workspace_dir / ".venv")])
        else:
            py = _python_for_venv()
            _run_explain([py, "-m", "venv", str(workspace_dir / ".venv")])
        vpy = _venv_python(workspace_dir)
        if not vpy.exists():
            raise SystemExit("Failed to create a Python virtualenv under .venv — see errors above.")

    # uv-created venvs intentionally ship without `pip`, so route installs through
    # `uv pip` whenever uv is on PATH — works for both uv- and stdlib-created venvs.
    if uv:
        _run_explain([uv, "pip", "install", "--python", str(vpy), "-r", str(req)])
    else:
        _run_explain([str(vpy), "-m", "pip", "install", "--upgrade", "pip"])
        _run_explain([str(vpy), "-m", "pip", "install", "-r", str(req)])
    stamp.parent.mkdir(parents=True, exist_ok=True)
    stamp.write_text(fp, encoding="utf-8")
    return vpy


def cmd_doctor(args: argparse.Namespace) -> int:
    verbose = getattr(args, "verbose", False)

    if not verbose:
        print("Minion — quick check")
        print("")
        ollama = _which("ollama")
        if ollama:
            try:
                _run(["ollama", "list"])
                print("Ollama: OK (local AI for your written profile)")
            except Exception:
                print("Ollama: installed but not responding — open the Ollama app or run: ollama serve")
        else:
            print("Ollama: not found — install from https://ollama.com for the profile step")

        uv = _which("uv")
        if uv:
            print("Optional speed-up (uv): OK")
        else:
            print("Optional speed-up (uv): not installed — we’ll use Python’s venv instead (fine)")

        print("")
        print("You’re good to run:  minion   or   minion start")
        print("Need details? Run:  minion doctor --verbose")
        return 0

    print("minion doctor (verbose)")
    print("")
    print(f"- repo_root: {_repo_root()}")
    print(f"- chatgpt_mcp_memory: {_chatgpt_mcp_dir()}")

    uv = _which("uv")
    print(f"- uv: {uv or 'missing'}")

    ollama = _which("ollama")
    print(f"- ollama: {ollama or 'missing'}")
    if ollama:
        try:
            out = _run(["ollama", "list"])
            print("- ollama list: ok")
            lines = [ln for ln in out.splitlines() if ln.strip()]
            for ln in lines[:8]:
                print(f"  {ln}")
            if len(lines) > 8:
                print("  …")
        except Exception:
            print("- ollama list: failed (is ollama running?)")

    return 0


_INGEST_BEGIN = "===INGEST_RESULT_BEGIN==="
_INGEST_END = "===INGEST_RESULT_END==="


def _parse_ingest_output(out: str) -> Tuple[str, str]:
    lines = [ln.rstrip("\n") for ln in out.splitlines()]
    stripped = [ln.strip() for ln in lines]

    # Preferred: sentinel-delimited result block (robust to stray progress lines).
    if _INGEST_BEGIN in stripped and _INGEST_END in stripped:
        i = stripped.index(_INGEST_BEGIN)
        j = stripped.index(_INGEST_END, i + 1)
        block = [ln for ln in stripped[i + 1 : j] if ln]
        if len(block) >= 2 and Path(block[0]).exists():
            return block[0], block[1]

    # Fallback for older ingest scripts: last two non-empty lines.
    non_empty = [ln for ln in stripped if ln]
    if len(non_empty) < 2:
        raise RuntimeError(f"Unexpected ingest output:\n{out}")
    export_root, manifest_path = non_empty[-2], non_empty[-1]
    if not Path(export_root).exists():
        raise RuntimeError(
            "Could not parse ingest paths (last lines were not export paths). Tail of output:\n"
            + "\n".join(non_empty[-12:])
        )
    return export_root, manifest_path


def _is_valid_export_path(p: Path) -> bool:
    return p.is_dir() or (p.is_file() and p.suffix.lower() == ".zip")


def _resolve_setup_export(args: argparse.Namespace) -> str:
    """
    Wizard passes export_zip; CLI may pass --export-zip and/or a positional path.
    """
    direct = getattr(args, "export_zip", None)
    opt = getattr(args, "export_zip_opt", None)
    pos = getattr(args, "export_zip_pos", None)
    if direct and (opt or pos):
        raise SystemExit(
            "minion setup: conflicting export paths (internal). "
            "If you see this, file an issue with how you invoked minion."
        )
    if direct:
        return str(direct)
    if opt and pos:
        if Path(opt).expanduser().resolve() != Path(pos).expanduser().resolve():
            raise SystemExit(
                "minion setup: you gave two different export paths. "
                "Use either the positional path or --export-zip, not both with different values."
            )
        return str(opt or pos)
    chosen = opt or pos
    if not chosen:
        raise SystemExit(
            "minion setup needs your ChatGPT export (the .zip from OpenAI, or an unzipped folder).\n"
            "\n"
            "  minion setup /path/to/export.zip\n"
            "  minion setup --export-zip /path/to/export.zip\n"
            "\n"
            "Or run  minion  with no arguments for the interactive wizard."
        )
    return str(chosen)


def _try_setup_shortcut(argv: List[str]) -> Optional[int]:
    """
    If argv is a single path to an existing export (.zip or folder), run setup without 'setup'.
    Example:  minion ./export.zip
    """
    if len(argv) != 1:
        return None
    raw = argv[0]
    if raw.startswith("-"):
        return None
    reserved = {
        "doctor",
        "setup",
        "quickstart",
        "eval",
        "mcp",
        "mcp-config",
        "ask_minion",
        "start",
        "wizard",
        "go",
        "help-me",
    }
    if raw in reserved:
        return None
    try:
        p = Path(raw).expanduser().resolve()
    except (OSError, RuntimeError):
        return None
    if not p.exists() or not _is_valid_export_path(p):
        return None
    ns = argparse.Namespace(
        export_zip=None,
        export_zip_opt=None,
        export_zip_pos=str(p),
        workspace=None,
        model="mistral:7b",
        with_ask_minion=False,
        plain=False,
    )
    return cmd_setup(ns)


def cmd_wizard() -> int:
    print()
    print("  Minion — set up your ChatGPT memory for Claude")
    print("  " + "—" * 42)
    print()
    print("  I’ll do the technical steps.")
    print("  You only need one thing: your ChatGPT export — either the .zip from OpenAI,")
    print("  or the folder after you unzip it.")
    print()
    print("  Drag the .zip or folder from Finder into this terminal window, or paste the full path:")
    raw = input("  > ").strip()
    raw = raw.strip("'\"")
    if not raw:
        print("  No path given. Stopping.")
        return 1
    export_path = Path(raw).expanduser().resolve()
    if not export_path.exists():
        print(f"  I can’t find that path: {export_path}")
        return 1
    if not _is_valid_export_path(export_path):
        print("  That doesn’t look like a .zip or a folder — use the export OpenAI sent you.")
        return 1

    workspace = _workspace_in_cwd()
    print()
    print(f"  Saving private data under:  {workspace}")

    print()
    model = "mistral:7b"
    print(f"  For the written profile I use a small local model via Ollama (default: {model}).")
    print(f"  If you don’t have it yet:  ollama pull {model}")

    ns = argparse.Namespace(
        export_zip=str(export_path),
        workspace=str(workspace),
        model=model,
        with_ask_minion=False,
        plain=True,
    )
    return cmd_setup(ns)


def cmd_setup(args: argparse.Namespace) -> int:
    plain = getattr(args, "plain", False)
    export_path = Path(_resolve_setup_export(args)).expanduser().resolve()
    if not export_path.exists():
        raise SystemExit(f"Missing export path: {export_path}")
    if not _is_valid_export_path(export_path):
        raise SystemExit(
            f"Not a ChatGPT export (.zip or folder): {export_path}"
        )

    ws_arg = getattr(args, "workspace", None)
    if ws_arg is None:
        workspace_dir = _workspace_beside_export(export_path)
    else:
        workspace_dir = Path(ws_arg).expanduser().resolve()
    _ensure_dir(workspace_dir)

    stamp = time.strftime("%Y-%m-%d_%H-%M-%S")
    run_dir = workspace_dir / "runs" / stamp
    raw_out_dir = run_dir / "raw"
    derived_dir = run_dir / "derived"
    _ensure_dir(raw_out_dir)
    _ensure_dir(derived_dir)

    vpy = _ensure_python_env(workspace_dir)

    if plain:
        print("Working folder (your data stays on this Mac):", workspace_dir)
        print("")
    else:
        print(f"Workspace: {workspace_dir}")
        print(f"Run dir:   {run_dir}")
        print("")

    # 1) Ingest zip (unzip into run_dir/raw/*)
    if plain:
        print("Step 1/5 — Opening your ChatGPT export…")
        print("  (Unzipping can take many minutes on a large export — progress lines below.)")
    else:
        print("1) Ingesting export zip…")
        print("   Unzipping; large exports take a while. You should see file counts stream below.")
    ingest_out = _run_tee(
        _python_u(vpy, _src("ingest_chatgpt_export.py"), [str(export_path), "--out", str(raw_out_dir)])
    )
    export_root, manifest_path = _parse_ingest_output(ingest_out)
    export_root_path = Path(export_root).expanduser().resolve()
    if not plain:
        print(f"   export_root: {export_root_path}")
        print(f"   manifest:    {manifest_path}")
        print("")

    # 2) Build semantic index into run_dir/derived
    if plain:
        print("Step 2/5 — Building a search index (this may take a while)…")
        print("  (Scanning messages → chunks → neural embeddings. Progress below.)")
    else:
        print("2) Building semantic index…")
        print("   Chunking messages, then embedding (tqdm progress bar may appear below).")
    _run_tee(
        _python_u(
            vpy,
            _src("build_index.py"),
            ["--export", str(export_root_path), "--derived-dir", str(derived_dir)],
        )
    )
    if not plain:
        print(f"   derived_dir: {derived_dir}")
        print("")

    # 3) Persona artifacts (sourcebook + quote bank)
    if plain:
        print("Step 3/5 — Gathering short quotes from your messages…")
        print("  (Re-reading the export to build persona_sourcebook + quote_bank.)")
    else:
        print("3) Extracting persona evidence…")
        print("   Scanning user messages for first-person lines (progress messages below).")
    _run_tee(
        _python_u(
            vpy,
            _src("persona_extract.py"),
            ["--export", str(export_root_path), "--derived-dir", str(derived_dir)],
        )
    )
    if not plain:
        print("")

    # 4) Generate core_profile.md from evidence (local Ollama)
    if plain:
        print("Step 4/5 — Writing your pasteable profile with the local AI (Ollama)…")
        print(f"  (Model: {args.model} — ensure Ollama is running.)")
    else:
        print("4) Generating core profile (local Ollama)…")
        print(f"   Calling model {args.model} (one request; may take several minutes).")
    core_profile_path = run_dir / "core_profile.md"
    agent_profile_path = run_dir / "agent_core_profile.md"
    gen_out = _run_tee(
        _python_u(
            vpy,
            _src("generate_core_profile.py"),
            [
                "--derived-dir",
                str(derived_dir),
                "--model",
                str(args.model),
                "--out-chatgpt-mcp",
                str(core_profile_path),
                "--out-agent",
                str(agent_profile_path),
            ],
        )
    )
    for ln in [ln.strip() for ln in gen_out.splitlines() if ln.strip()][-3:]:
        print(f"   {ln}")
    print("")

    retrieval_policy_src = _chatgpt_mcp_dir() / "retrieval_policy.md"
    retrieval_policy_run = run_dir / "retrieval_policy.md"
    retrieval_policy_derived = derived_dir / "retrieval_policy.md"
    if retrieval_policy_src.exists():
        shutil.copy2(retrieval_policy_src, retrieval_policy_run)
        shutil.copy2(retrieval_policy_src, retrieval_policy_derived)

    # Deterministic brief for the MCP server to auto-attach on first tool call.
    # The server prefers richer core_profile.md / identity_profile.md when present,
    # so this is strictly a fallback; generating it is still cheap and useful for eval.
    try:
        _run_tee(
            _python_u(vpy, _src("build_brief.py"), ["--derived-dir", str(derived_dir)])
        )
    except Exception as e:
        print(f"   Warning: brief.md not generated: {e}")

    # Durable voice profile (nevers / preferences / style / samples) — injected
    # into initialize.instructions every session. Non-fatal like the brief.
    try:
        _run_tee(
            _python_u(vpy, _src("build_voice.py"), ["--derived-dir", str(derived_dir)])
        )
    except Exception as e:
        print(f"   Warning: voice.md not generated: {e}")

    if plain:
        print("Step 5/5 — Connecting memory search to Claude Desktop…")
    else:
        print("5) Updating Claude Desktop MCP config…")
    try:
        cfg_written, cfg_backup = install_claude_desktop_mcp(
            workspace_dir=workspace_dir,
            derived_dir=derived_dir,
            server_name="minion",
            config_path=None,
        )
        if plain:
            print(f"  Updated: {cfg_written}")
            if cfg_backup is not None:
                print(f"  Backup:  {cfg_backup}")
        else:
            print(f"   {cfg_written}")
            if cfg_backup is not None:
                print(f"   backup: {cfg_backup}")
    except Exception as e:
        if plain:
            print(f"  Could not update automatically: {e}")
            print(f'  Run:  minion mcp-config --derived-dir "{derived_dir}"')
        else:
            print(f"   Warning: {e}")
            print(f'   Run:  minion mcp-config --derived-dir "{derived_dir}"')
    print("")

    if plain:
        print("All set.")
        print("")
        print("What you do next (in Claude) — two different things:")
        print("")
        print("  A) Tools wired (already done): step 5 wrote the Minion MCP into Claude Desktop’s")
        print("     config file so Claude can *see* ask_minion / get_chunk. Quit and reopen")
        print("     Claude Desktop so that takes effect.")
        print("")
        print("  B) Paste into Claude — profile only (required):")
        print("")
        print("     • Retrieval rules: Minion already put retrieval_policy.md next to your index;")
        print("       the MCP server injects that text when Claude connects (no paste needed")
        print("       for that part). Optional: paste the same file into Custom Instructions too.")
        print("")
        print("     • Your voice / facts — paste this into Custom Instructions (or project):")
        print(f"        {core_profile_path}")
        print("")
    else:
        print("Done.")
        print("")
        print(f"- Pasteable profile: {core_profile_path}")
        if retrieval_policy_run.exists():
            print(f"- retrieval_policy.md (injected via MCP initialize; also at): {retrieval_policy_run}")
        print(f"- Derived data dir: {derived_dir}")
        print("")
        print("Claude: restart Desktop (MCP). Paste core_profile into Custom Instructions; retrieval")
        print("policy is injected from derived/retrieval_policy.md when the MCP session starts.")
        print("")

        if getattr(args, "with_ask_minion", False):
            print("Optional — ask_minion (chunk-native identity_profile.md, many Ollama calls)…")
            print("   This step runs one extract pass per conversation — can take hours on a huge corpus.")
            ask_out = _run_tee(
                _python_u(
                    vpy,
                    _src("ask_minion.py"),
                    [
                        "--derived-dir",
                        str(derived_dir),
                        "--model",
                        str(args.model),
                    ],
                )
            )
            for ln in [ln.strip() for ln in ask_out.splitlines() if ln.strip()][-4:]:
                print(f"   {ln}")
            print("")

        print("Next:")
        print(f'  minion mcp-config --derived-dir "{derived_dir}"   # re-apply Claude Desktop config if needed')
        print(f'  minion mcp --derived-dir "{derived_dir}"')
        if not getattr(args, "with_ask_minion", False):
            print(f'  minion ask_minion --derived-dir "{derived_dir}" --model {args.model}')
    return 0


def cmd_quickstart(args: argparse.Namespace) -> int:
    """
    v1 minimal pipeline: zip -> embed -> MCP in Claude. Skips persona / Ollama.
    """
    export_path = Path(_resolve_setup_export(args)).expanduser().resolve()
    if not export_path.exists():
        raise SystemExit(f"Missing export path: {export_path}")
    if not _is_valid_export_path(export_path):
        raise SystemExit(f"Not a ChatGPT export (.zip or folder): {export_path}")

    ws_arg = getattr(args, "workspace", None)
    workspace_dir = (
        Path(ws_arg).expanduser().resolve() if ws_arg else _workspace_beside_export(export_path)
    )
    _ensure_dir(workspace_dir)

    stamp = time.strftime("%Y-%m-%d_%H-%M-%S")
    run_dir = workspace_dir / "runs" / stamp
    raw_out_dir = run_dir / "raw"
    derived_dir = run_dir / "derived"
    _ensure_dir(raw_out_dir)
    _ensure_dir(derived_dir)

    vpy = _ensure_python_env(workspace_dir)

    print(f"Workspace: {workspace_dir}")
    print(f"Run dir:   {run_dir}")
    print("")

    print("1/3 Ingesting export…")
    ingest_out = _run_tee(
        _python_u(vpy, _src("ingest_chatgpt_export.py"), [str(export_path), "--out", str(raw_out_dir)])
    )
    export_root, manifest_path = _parse_ingest_output(ingest_out)
    export_root_path = Path(export_root).expanduser().resolve()
    print(f"   export_root: {export_root_path}")
    print(f"   manifest:    {manifest_path}")
    print("")

    print("2/3 Building semantic index (fastembed)…")
    build_args = [
        "--export",
        str(export_root_path),
        "--derived-dir",
        str(derived_dir),
    ]
    if getattr(args, "include_assistant", False):
        build_args.append("--include-assistant")
    _run_tee(_python_u(vpy, _src("build_index.py"), build_args))
    print(f"   derived_dir: {derived_dir}")
    print("")

    retrieval_policy_src = _chatgpt_mcp_dir() / "retrieval_policy.md"
    if retrieval_policy_src.exists():
        shutil.copy2(retrieval_policy_src, run_dir / "retrieval_policy.md")
        shutil.copy2(retrieval_policy_src, derived_dir / "retrieval_policy.md")

    # Deterministic brief (preferences, names, frameworks) auto-attached by the
    # MCP server on the first tool call of each Claude session. Non-fatal: a missing
    # brief just skips injection, it does not block wiring up the MCP server.
    try:
        _run_tee(
            _python_u(vpy, _src("build_brief.py"), ["--derived-dir", str(derived_dir)])
        )
    except Exception as e:
        print(f"   Warning: brief.md not generated: {e}")

    # Voice profile — durable nevers/preferences/style directives injected into
    # initialize.instructions every session. Non-fatal.
    try:
        _run_tee(
            _python_u(vpy, _src("build_voice.py"), ["--derived-dir", str(derived_dir)])
        )
    except Exception as e:
        print(f"   Warning: voice.md not generated: {e}")

    print("3/3 Installing MCP into Claude Desktop config…")
    try:
        cfg_written, cfg_backup = install_claude_desktop_mcp(
            workspace_dir=workspace_dir,
            derived_dir=derived_dir,
            server_name="minion",
            config_path=None,
        )
        print(f"   {cfg_written}")
        if cfg_backup is not None:
            print(f"   backup: {cfg_backup}")
    except Exception as e:
        print(f"   Warning: {e}")
        print(f'   Run:  minion mcp-config --derived-dir "{derived_dir}"')
    print("")

    print("Done. Next:")
    print("  - Restart Claude Desktop so it picks up the MCP server.")
    print(f'  - Sanity-check: minion eval --derived-dir "{derived_dir}"')
    return 0


def cmd_build_brief(args: argparse.Namespace) -> int:
    """Regenerate <derived>/brief.md from chunks.jsonl (deterministic, no Ollama)."""
    derived_dir = Path(args.derived_dir).expanduser().resolve()
    if not derived_dir.exists():
        raise SystemExit(f"Missing derived dir: {derived_dir}")

    workspace_dir = (
        Path(args.workspace).expanduser().resolve() if args.workspace else _default_workspace_dir()
    )
    vpy = _ensure_python_env(workspace_dir)

    extra: List[str] = ["--derived-dir", str(derived_dir)]
    if getattr(args, "max_chars", None):
        extra.extend(["--max-chars", str(args.max_chars)])
    _run_tee(_python_u(vpy, _src("build_brief.py"), extra))
    return 0


def cmd_build_voice(args: argparse.Namespace) -> int:
    """Ensure <derived>/voice.md exists as a bootstrap-ready skeleton.

    voice.md is built by Claude itself on the first MCP session: the bootstrap
    directive in `initialize.instructions` drives Claude to gather evidence via
    `ask_minion` + `browse_conversations`, then persist the synthesized profile
    via `commit_voice`. This command only ensures the skeleton file with both
    sentinels exists, so the MCP server can detect "unbuilt" state and trigger
    the bootstrap. User hand-edits below the <!-- MINION_VOICE_USER_EDITS -->
    sentinel are preserved across runs.
    """
    derived_dir = Path(args.derived_dir).expanduser().resolve()
    if not derived_dir.exists():
        raise SystemExit(f"Missing derived dir: {derived_dir}")

    workspace_dir = (
        Path(args.workspace).expanduser().resolve() if args.workspace else _default_workspace_dir()
    )
    vpy = _ensure_python_env(workspace_dir)

    _run_tee(_python_u(vpy, _src("build_voice.py"), ["--derived-dir", str(derived_dir)]))
    return 0


def cmd_eval(args: argparse.Namespace) -> int:
    derived_dir = Path(args.derived_dir).expanduser().resolve()
    if not derived_dir.exists():
        raise SystemExit(f"Missing derived dir: {derived_dir}")

    workspace_dir = (
        Path(args.workspace).expanduser().resolve() if args.workspace else _default_workspace_dir()
    )
    vpy = _ensure_python_env(workspace_dir)

    runner = _repo_root() / "eval" / "run_eval.py"
    if not runner.exists():
        raise SystemExit(f"Missing eval runner: {runner}")

    cmd: List[str] = [str(vpy), "-u", str(runner), "--derived-dir", str(derived_dir)]
    if args.golden:
        cmd.extend(["--golden", str(Path(args.golden).expanduser().resolve())])
    if args.server_py:
        cmd.extend(["--server-py", str(Path(args.server_py).expanduser().resolve())])
    if args.top_k is not None:
        cmd.extend(["--top-k", str(args.top_k)])
    if args.json:
        cmd.append("--json")

    env = dict(os.environ)
    env["MINION_DATA_DIR"] = str(derived_dir)
    # Drive through _run_tee so users see progress; returncode propagates.
    try:
        _run_tee(cmd, env=env)
    except subprocess.CalledProcessError as e:
        return int(e.returncode or 1)
    return 0


def cmd_mcp_config(args: argparse.Namespace) -> int:
    """Merge Minion MCP into Claude Desktop's claude_desktop_config.json (default), or --print-only JSON."""
    workspace_dir = Path(args.workspace).expanduser().resolve()
    derived_dir = Path(args.derived_dir).expanduser().resolve()
    server_name = str(args.server_name or "minion")
    quiet = getattr(args, "quiet", False)
    print_only = getattr(args, "print_only", False)

    if print_only:
        vpy = _ensure_python_env(workspace_dir)
        mcp_script = _src("mcp_server.py")
        # See install_claude_desktop_mcp: never resolve() the venv python, or
        # Python will load the system site-packages and miss numpy/fastembed.
        payload = {
            "mcpServers": {
                server_name: {
                    "command": str(vpy),
                    "args": [str(mcp_script.resolve())],
                    "env": {"MINION_DATA_DIR": str(derived_dir)},
                }
            }
        }
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        if not quiet:
            print("", file=sys.stderr)
            print("(print-only: nothing written to Claude Desktop config)", file=sys.stderr)
        return 0

    cfg_path_arg = getattr(args, "config_path", None)
    cfg_override = Path(cfg_path_arg).expanduser().resolve() if cfg_path_arg else None
    written, backup = install_claude_desktop_mcp(
        workspace_dir=workspace_dir,
        derived_dir=derived_dir,
        server_name=server_name,
        config_path=cfg_override,
    )
    policy_src = _chatgpt_mcp_dir() / "retrieval_policy.md"
    policy_dst = derived_dir / "retrieval_policy.md"
    if policy_src.exists():
        shutil.copy2(policy_src, policy_dst)
        if not quiet:
            print("Copied retrieval_policy.md into derived dir (MCP injects this via initialize.instructions):", file=sys.stderr)
            print(f"  {policy_dst}", file=sys.stderr)
    if not quiet:
        print(f'Wrote MCP server "{server_name}" into Claude Desktop config:', file=sys.stderr)
        print(f"  {written}", file=sys.stderr)
        if backup is not None:
            print(f"Backup of previous file: {backup}", file=sys.stderr)
        print("Restart Claude Desktop to load the server.", file=sys.stderr)
    return 0


def cmd_mcp(args: argparse.Namespace) -> int:
    derived_dir = Path(args.derived_dir).expanduser().resolve()
    if not derived_dir.exists():
        raise SystemExit(f"Missing derived dir: {derived_dir}")

    workspace_dir = Path(args.workspace).expanduser().resolve() if args.workspace else _default_workspace_dir()
    vpy = _ensure_python_env(workspace_dir)

    env = dict(os.environ)
    env["MINION_DATA_DIR"] = str(derived_dir)
    # Run MCP server over stdio; Claude Desktop starts this process.
    os.execve(
        str(vpy),
        [str(vpy), str(_src("mcp_server.py"))],
        env,
    )
    return 0


def _derived_dir_default() -> Path:
    """Best-effort default derived dir when one isn't supplied on the CLI."""
    env = os.environ.get("MINION_DATA_DIR")
    if env:
        return Path(env).expanduser().resolve()
    ws = _default_workspace_dir()
    cand = ws / "data" / "derived"
    if cand.exists():
        return cand
    return _chatgpt_mcp_dir() / "data" / "derived"


def _run_in_venv(script: str, extra_args: List[str], *, workspace: Optional[Path] = None) -> int:
    """Invoke a src/*.py script inside the project venv so imports (sqlite_vec, etc.) work."""
    workspace_dir = (workspace or _default_workspace_dir()).expanduser().resolve()
    vpy = _ensure_python_env(workspace_dir)
    cmd = [str(vpy), str(_src(script))] + extra_args
    result = subprocess.run(cmd)
    return int(result.returncode)


def cmd_watch(args: argparse.Namespace) -> int:
    derived = Path(args.derived_dir or _derived_dir_default()).expanduser().resolve()
    derived.mkdir(parents=True, exist_ok=True)
    extra: List[str] = ["--data-dir", str(derived)]
    if args.inbox:
        extra.extend(["--inbox", str(Path(args.inbox).expanduser().resolve())])
    if args.once:
        extra.append("--once")
    if args.force:
        extra.append("--force")
    if not args.quiet:
        extra.append("--verbose")
    return _run_in_venv("watcher.py", extra, workspace=Path(args.workspace) if args.workspace else None)


def _cli_add(derived: Path, paths: List[Path], *, force: bool, workspace: Optional[Path]) -> int:
    """Explicit ingest: parse+embed+upsert each path into the DB."""
    script = """
import json, sys
from pathlib import Path
from store import DB_FILENAME, connect
from ingest import ingest_file

data_dir = Path(sys.argv[1])
force = sys.argv[2] == '1'
paths = [Path(p) for p in sys.argv[3:]]
conn = connect(data_dir / DB_FILENAME)
for p in paths:
    res = ingest_file(conn, p, force=force)
    print(json.dumps({
        'path': res.path, 'source_id': res.source_id, 'kind': res.kind,
        'parser': res.parser, 'chunks': res.chunk_count,
        'skipped': res.skipped, 'reason': res.reason,
    }, ensure_ascii=False))
"""
    workspace_dir = (workspace or _default_workspace_dir()).expanduser().resolve()
    vpy = _ensure_python_env(workspace_dir)
    cmd = [str(vpy), "-c", script, str(derived), "1" if force else "0", *[str(p) for p in paths]]
    env = dict(os.environ)
    env["PYTHONPATH"] = str(_src("x").parent) + os.pathsep + env.get("PYTHONPATH", "")
    result = subprocess.run(cmd, env=env)
    return int(result.returncode)


def cmd_add(args: argparse.Namespace) -> int:
    derived = Path(args.derived_dir or _derived_dir_default()).expanduser().resolve()
    derived.mkdir(parents=True, exist_ok=True)
    paths = [Path(p).expanduser().resolve() for p in args.paths]
    missing = [p for p in paths if not p.exists()]
    if missing:
        print("Missing paths: " + ", ".join(str(m) for m in missing), file=sys.stderr)
        return 2
    return _cli_add(derived, paths, force=args.force, workspace=Path(args.workspace) if args.workspace else None)


def cmd_rm(args: argparse.Namespace) -> int:
    derived = Path(args.derived_dir or _derived_dir_default()).expanduser().resolve()
    script = """
import sys
from pathlib import Path
from store import DB_FILENAME, connect, delete_source, delete_source_by_path

data_dir = Path(sys.argv[1])
conn = connect(data_dir / DB_FILENAME)
total = 0
for target in sys.argv[2:]:
    if target.startswith('src-'):
        n = delete_source(conn, target)
    else:
        n = delete_source_by_path(conn, str(Path(target).expanduser().resolve()))
    print(f'{target}: removed {n} chunks')
    total += n
print(f'total removed chunks: {total}')
"""
    workspace_dir = (Path(args.workspace) if args.workspace else _default_workspace_dir()).expanduser().resolve()
    vpy = _ensure_python_env(workspace_dir)
    env = dict(os.environ)
    env["PYTHONPATH"] = str(_src("x").parent) + os.pathsep + env.get("PYTHONPATH", "")
    cmd = [str(vpy), "-c", script, str(derived), *args.targets]
    result = subprocess.run(cmd, env=env)
    return int(result.returncode)


def cmd_ls(args: argparse.Namespace) -> int:
    derived = Path(args.derived_dir or _derived_dir_default()).expanduser().resolve()
    script = """
import json, sys, time
from pathlib import Path
from store import DB_FILENAME, connect, list_sources, count_chunks, count_sources

data_dir = Path(sys.argv[1])
kind = sys.argv[2] or None
path_glob = sys.argv[3] or None
as_json = sys.argv[4] == '1'
conn = connect(data_dir / DB_FILENAME)
rows = list_sources(conn, kind=kind, path_glob=path_glob, limit=1000)
if as_json:
    print(json.dumps({'sources': rows, 'total_chunks': count_chunks(conn)}, indent=2, ensure_ascii=False))
else:
    print(f"{count_sources(conn)} sources, {count_chunks(conn)} chunks")
    for r in rows:
        ts = time.strftime('%Y-%m-%d', time.localtime(r['mtime'])) if r.get('mtime') else '-'
        print(f"  [{r['kind']:>14}] {r['chunk_count']:>5}c {ts}  {r['path']}")
"""
    workspace_dir = (Path(args.workspace) if args.workspace else _default_workspace_dir()).expanduser().resolve()
    vpy = _ensure_python_env(workspace_dir)
    env = dict(os.environ)
    env["PYTHONPATH"] = str(_src("x").parent) + os.pathsep + env.get("PYTHONPATH", "")
    cmd = [
        str(vpy), "-c", script, str(derived),
        args.kind or "", args.path_glob or "", "1" if args.json else "0",
    ]
    result = subprocess.run(cmd, env=env)
    return int(result.returncode)


def cmd_ask_minion(args: argparse.Namespace) -> int:
    workspace_dir = Path(args.workspace).expanduser().resolve()
    vpy = _ensure_python_env(workspace_dir)
    derived_dir = Path(args.derived_dir).expanduser().resolve()
    cmd: List[str] = [
        str(vpy),
        str(_src("ask_minion.py")),
        "--derived-dir",
        str(derived_dir),
        "--model",
        str(args.model),
    ]
    if args.dry_run:
        cmd.append("--dry-run")
    if args.max_conversations is not None:
        cmd.extend(["--max-conversations", str(args.max_conversations)])
    if args.sample_every_n != 1:
        cmd.extend(["--sample-every-n", str(args.sample_every_n)])
    if args.since_unix is not None:
        cmd.extend(["--since-unix", str(args.since_unix)])
    if args.timeout_seconds is not None:
        cmd.extend(["--timeout-seconds", str(args.timeout_seconds)])
    if args.chunks:
        cmd.extend(["--chunks", str(Path(args.chunks).expanduser().resolve())])
    if args.out:
        cmd.extend(["--out", str(Path(args.out).expanduser().resolve())])
    if args.save_extractions:
        cmd.extend(["--save-extractions", str(Path(args.save_extractions).expanduser().resolve())])
    if args.max_window_chars != 14000:
        cmd.extend(["--max-window-chars", str(args.max_window_chars)])

    out = _run(cmd)
    print(out, end="")
    return 0


def main(argv: Optional[List[str]] = None) -> int:
    argv = argv if argv is not None else sys.argv[1:]
    if not argv or argv[0] in ("start", "wizard", "go", "help-me"):
        return cmd_wizard()

    short = _try_setup_shortcut(argv)
    if short is not None:
        return short

    parser = argparse.ArgumentParser(
        prog="minion",
        description="Local-first memory + persona for Claude. Run with no arguments for a guided setup.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Examples:\n"
        "  minion\n"
        "  minion ./chatgpt-export.zip\n"
        "  minion setup ~/Downloads/chatgpt-export.zip\n"
        "  minion doctor\n",
    )
    sub = parser.add_subparsers(dest="cmd", required=True, metavar="cmd")

    p_doctor = sub.add_parser("doctor", help="Check local prerequisites.")
    p_doctor.add_argument("--verbose", action="store_true", help="Show technical paths and full Ollama list")
    p_doctor.set_defaults(func=cmd_doctor)

    p_setup = sub.add_parser(
        "setup",
        help="Ingest ChatGPT export (.zip or folder) and build everything into a private workspace.",
        description="Pass your export as the first argument, or use --export-zip. "
        "Large exports take a while; you will see progress in the terminal.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Example:  minion setup ~/Downloads/export.zip",
    )
    p_setup.add_argument(
        "--export-zip",
        "--export",
        required=False,
        default=None,
        dest="export_zip_opt",
        metavar="PATH",
        help="ChatGPT export: .zip from OpenAI or an unzipped folder (same as the positional argument)",
    )
    p_setup.add_argument(
        "--workspace",
        default=None,
        help="Private workspace directory (default: minion_private next to the export)",
    )
    p_setup.add_argument("--model", default="mistral:7b", help="Ollama model for profile generation")
    p_setup.add_argument(
        "--with-ask-minion",
        action="store_true",
        help="After setup, run ask_minion (chunk→identity_profile.md; can take a long time)",
    )
    p_setup.add_argument("--plain", action="store_true", help=argparse.SUPPRESS)
    p_setup.add_argument(
        "export_zip_pos",
        nargs="?",
        default=None,
        metavar="EXPORT",
        help="ChatGPT export (.zip or folder). You can use this instead of --export-zip.",
    )
    p_setup.set_defaults(func=cmd_setup)

    p_quick = sub.add_parser(
        "quickstart",
        help="Minimal v1 pipeline: ingest zip -> build semantic index -> install MCP into Claude.",
        description="Skips persona/Ollama steps. Intended for the fastest path to a working MCP.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Example:  minion quickstart ~/Downloads/export.zip",
    )
    p_quick.add_argument(
        "--export-zip",
        "--export",
        required=False,
        default=None,
        dest="export_zip_opt",
        metavar="PATH",
        help="ChatGPT export: .zip or unzipped folder (same as the positional argument)",
    )
    p_quick.add_argument(
        "--workspace",
        default=None,
        help="Private workspace directory (default: minion_private next to the export)",
    )
    p_quick.add_argument(
        "--include-assistant",
        action="store_true",
        help="Index assistant messages too (default: user-only)",
    )
    p_quick.add_argument(
        "export_zip_pos",
        nargs="?",
        default=None,
        metavar="EXPORT",
        help="ChatGPT export (.zip or folder). You can use this instead of --export-zip.",
    )
    p_quick.set_defaults(func=cmd_quickstart)

    p_brief = sub.add_parser(
        "build-brief",
        help="Regenerate <derived>/brief.md (deterministic profile the MCP auto-attaches on first tool call).",
    )
    p_brief.add_argument(
        "--derived-dir",
        required=True,
        help="Derived dir containing chunks.jsonl.",
    )
    p_brief.add_argument(
        "--workspace",
        default=None,
        help="Workspace whose .venv provides the Python runtime.",
    )
    p_brief.add_argument(
        "--max-chars",
        type=int,
        default=None,
        help="Hard cap on brief.md size (default 4000; env MINION_BRIEF_MAX_CHARS).",
    )
    p_brief.set_defaults(func=cmd_build_brief)

    p_voice = sub.add_parser(
        "build-voice",
        help=(
            "Ensure <derived>/voice.md skeleton exists (Claude bootstraps the "
            "actual voice directives on the first MCP session)."
        ),
    )
    p_voice.add_argument(
        "--derived-dir",
        required=True,
        help="Derived dir containing chunks.jsonl.",
    )
    p_voice.add_argument(
        "--workspace",
        default=None,
        help="Workspace whose .venv provides the Python runtime.",
    )
    p_voice.set_defaults(func=cmd_build_voice)

    p_eval = sub.add_parser(
        "eval",
        help="Run golden-query test harness against the MCP server over stdio.",
    )
    p_eval.add_argument(
        "--derived-dir",
        required=True,
        help="Derived dir (chunks/embeddings/manifest) the MCP will serve.",
    )
    p_eval.add_argument(
        "--workspace",
        default=None,
        help="Workspace whose .venv runs the MCP (default: home minion_private).",
    )
    p_eval.add_argument(
        "--golden",
        default=None,
        help="Path to golden_queries.yaml (default: <repo>/eval/golden_queries.yaml).",
    )
    p_eval.add_argument(
        "--server-py",
        default=None,
        help="Override MCP server script path (default: chatgpt_mcp_memory/src/mcp_server.py).",
    )
    p_eval.add_argument("--top-k", type=int, default=None, help="Override top_k for all queries.")
    p_eval.add_argument("--json", action="store_true", help="Emit machine-readable JSON report to stdout.")
    p_eval.set_defaults(func=cmd_eval)

    p_mcpcfg = sub.add_parser(
        "mcp-config",
        help="Merge Minion into Claude Desktop claude_desktop_config.json (default). Use --print-only for JSON only.",
    )
    p_mcpcfg.add_argument(
        "--derived-dir",
        required=True,
        help="Directory with chunks.jsonl / embeddings (same as MINION_DATA_DIR)",
    )
    p_mcpcfg.add_argument("--workspace", default=str(_default_workspace_dir()), help="Workspace whose .venv runs the MCP")
    p_mcpcfg.add_argument(
        "--server-name",
        default="minion",
        help="Key name under mcpServers (default: minion)",
    )
    p_mcpcfg.add_argument(
        "--config-path",
        default=None,
        help="Override Claude config path (default: macOS/Windows path, or CLAUDE_DESKTOP_CONFIG)",
    )
    p_mcpcfg.add_argument(
        "--print-only",
        action="store_true",
        help="Print mcpServers JSON only; do not write the config file",
    )
    p_mcpcfg.add_argument(
        "--quiet",
        action="store_true",
        help="With --print-only: JSON only. When writing: no stderr messages.",
    )
    p_mcpcfg.set_defaults(func=cmd_mcp_config)

    p_mcp = sub.add_parser("mcp", help="Run the MCP server pointing at a derived directory.")
    p_mcp.add_argument("--derived-dir", required=True, help="Directory containing chunks/embeddings/manifest")
    p_mcp.add_argument("--workspace", default=str(_default_workspace_dir()), help="Workspace to host the venv")
    p_mcp.set_defaults(func=cmd_mcp)

    p_ask = sub.add_parser(
        "ask_minion",
        help="Synthesize identity_profile.md from chunks.jsonl (map→reduce via local Ollama).",
    )
    p_ask.add_argument("--derived-dir", required=True, help="Directory containing chunks.jsonl (and outputs)")
    p_ask.add_argument("--workspace", default=str(_default_workspace_dir()), help="Workspace with .venv for dependencies")
    p_ask.add_argument("--model", default="mistral:7b", help="Ollama model")
    p_ask.add_argument("--dry-run", action="store_true", help="Load chunks and print stats only")
    p_ask.add_argument("--max-conversations", type=int, default=None)
    p_ask.add_argument("--sample-every-n", type=int, default=1)
    p_ask.add_argument("--since-unix", type=float, default=None)
    p_ask.add_argument("--timeout-seconds", type=float, default=None)
    p_ask.add_argument("--chunks", default=None, help="Override path to chunks.jsonl")
    p_ask.add_argument("--out", default=None, help="Output markdown path")
    p_ask.add_argument("--save-extractions", default=None, help="JSONL path for per-conversation extractions")
    p_ask.add_argument("--max-window-chars", type=int, default=14000)
    p_ask.set_defaults(func=cmd_ask_minion)

    p_watch = sub.add_parser(
        "watch",
        help="Watch <data_dir>/../inbox and auto-ingest dropped files (docs, pdfs, images, audio, code).",
    )
    p_watch.add_argument("--derived-dir", default=None, help="Directory holding memory.db (default: $MINION_DATA_DIR or minion_private/data/derived)")
    p_watch.add_argument("--inbox", default=None, help="Inbox directory (default: <derived>/../inbox)")
    p_watch.add_argument("--once", action="store_true", help="Reconcile and exit")
    p_watch.add_argument("--force", action="store_true", help="Re-ingest unchanged files")
    p_watch.add_argument("--quiet", action="store_true", help="Suppress per-file INFO logs")
    p_watch.add_argument("--workspace", default=None, help="Workspace whose .venv runs the watcher")
    p_watch.set_defaults(func=cmd_watch)

    p_add = sub.add_parser(
        "add",
        help="Ingest one or more files directly into memory.db (bypasses the inbox).",
    )
    p_add.add_argument("paths", nargs="+", help="Files to ingest")
    p_add.add_argument("--derived-dir", default=None, help="Directory holding memory.db")
    p_add.add_argument("--force", action="store_true", help="Re-ingest even if the sha256 matches")
    p_add.add_argument("--workspace", default=None, help="Workspace whose .venv runs ingest")
    p_add.set_defaults(func=cmd_add)

    p_rm = sub.add_parser(
        "rm",
        help="Remove sources from memory.db by path or source_id.",
    )
    p_rm.add_argument("targets", nargs="+", help="Paths or source_ids (src-*) to remove")
    p_rm.add_argument("--derived-dir", default=None, help="Directory holding memory.db")
    p_rm.add_argument("--workspace", default=None, help="Workspace whose .venv runs delete")
    p_rm.set_defaults(func=cmd_rm)

    p_ls = sub.add_parser(
        "ls",
        help="List indexed sources grouped by kind.",
    )
    p_ls.add_argument("--derived-dir", default=None, help="Directory holding memory.db")
    p_ls.add_argument("--kind", default=None, help="Filter by kind (text/pdf/image/audio/code/...)")
    p_ls.add_argument("--path-glob", default=None, help="SQL GLOB over path")
    p_ls.add_argument("--json", action="store_true", help="JSON output")
    p_ls.add_argument("--workspace", default=None, help="Workspace whose .venv runs query")
    p_ls.set_defaults(func=cmd_ls)

    args = parser.parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())

